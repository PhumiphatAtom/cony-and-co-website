# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cony_co

# JWT (minimum 32 characters each)
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxx

# Google Sheets (Service Account JSON as single-line string)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Server
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
